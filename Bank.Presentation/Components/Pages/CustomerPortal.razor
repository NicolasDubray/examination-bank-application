@page "/portal/{CustomerId:int}"
@inject NavigationManager NavigationManager
@inject AccountService AccountService
@inject CustomerService CustomerService
@inject TransactionService TransactionService

<button @onclick="GoToCustomerSelection">Back to customer selection</button>
<hr/>
<h3>Customer Portal</h3>
<hr/>

@if (customerOverview is not null)
{
    <!-- Accounts table -->
    <h4>@customerOverview.FullName</h4>
    <hr/>
    <h5>Accounts</h5>
    <table class="accounts-table">
        <thead>
            <tr>
                <th>Account</th>
                <th>Type</th>
                <th class="amount">Balance</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var account in customerOverview.Accounts)
            {
                <tr class="account-row @(selectedAccountId == account.Id ? "selected" : "")"
                @onclick="() => SelectAccount(account.Id)">

                    <td>@account.AccountNumber</td>
                    <td>@account.AccountType</td>
                    <td class="amount">@account.Balance</td>
                </tr>
            }
        </tbody>
    </table>
    <hr/>  

    <!-- Account details card -->
    @if (accountDetails is not null)
    {
        <div class="account-details-card">
            <h4>Account Details</h4>
            <div class="detail-row">
                <span class="label">Account Number</span>
                <span class="data">@accountDetails.AccountNumber</span>
            </div>
            <div class="detail-row">
                <span class="label">Type</span>
                <span class="data">@accountDetails.AccountType</span>
            </div>
            <div class="detail-row">
                <span class="label">Balance</span>
                <span class="amount">@accountDetails.Balance</span>
            </div>
            <div class="detail-row">
                <span class="label">Withdrawal Limit</span>
                <span class="amount">@accountDetails.WithdrawalLimit</span>
            </div>
        </div>
        <hr/>
    }

    <!-- Transaction filter controls -->
    <div class="transaction-filter-controls">
        <label>
            From:
            <input type="date" @bind="fromDateFilterSetting" />
        </label>
        <label>
            To:
            <input type="date" @bind="toDateFilterSetting" />
        </label>
        <label>
            Type:
            <select @bind="transactionTypeFilterSetting">
                <option value="">All</option>
                <option value="Deposit">Deposit</option>
                <option value="Withdrawal">Withdrawal</option>
                <option value="Transfer">Transfer</option>
            </select>
        </label>
        <label>
            <input type="checkbox" @bind="shouldOrderTransactionsByDescending" />
            Newest first
        </label>
        <button @onclick="LoadTransactions">
            Apply filters
        </button>
    </div>

    <!-- Transactions table -->
    @if (transactionsForSelectedAccount is not null)
    {
        <table class="transactions-table">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Description</th>                    
                    <th>Amount</th>
                    <th>Type</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in transactionsForSelectedAccount)
                {                    
                    <tr>
                        <td>@t.Date.ToString("yyyy-MM-dd")</td>
                        <td>@t.Description</td>                        
                        <td class="amount">
                            @(t.Amount >= 0 ? "+" : "-")@Math.Abs(t.Amount)
                        </td>
                        <td>@t.Type</td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    private int? selectedAccountId;

    private CustomerOverviewDto? customerOverview;
    private AccountDetailsDto? accountDetails;
    private List<TransactionDto> transactionsForSelectedAccount = new();

    private DateTime? fromDateFilterSetting;
    private DateTime? toDateFilterSetting;
    private string? transactionTypeFilterSetting;
    private bool shouldOrderTransactionsByDescending = true;

    [Parameter] public int CustomerId { get; set; }

    protected override void OnParametersSet() =>
        customerOverview = CustomerService.GetCustomerOverview(CustomerId);

    private void SelectAccount(int accountId)
    {
        selectedAccountId = accountId;
        accountDetails = AccountService.GetAccountDetails(accountId);
        LoadTransactions();
    }

    private void LoadTransactions()
    {
        if (selectedAccountId is null)
            return;

        transactionsForSelectedAccount =
            AccountService.GetAccountTransactions(
                selectedAccountId.Value,
                new TransactionFilterDto(
                    fromDateFilterSetting,
                    toDateFilterSetting,
                    transactionTypeFilterSetting),
                shouldOrderTransactionsByDescending
            );
    }

    private void GoToCustomerSelection() =>
        NavigationManager.NavigateTo("/select-customer");
}
